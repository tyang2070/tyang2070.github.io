---
import Layout from '../layouts/Layout.astro';
import { readdirSync } from 'fs';
import { join } from 'path';
import { marked } from 'marked';
import { readFileSync } from 'fs';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const bioRaw = readFileSync(join(process.cwd(), 'src/content/bio.md'), 'utf-8');
const bioHtml = marked(bioRaw);

const imageExts = ['.jpg', '.jpeg', '.png', '.gif', '.webp', '.avif'];
const galleryDir = join(process.cwd(), 'public/gallery');
const photos = readdirSync(galleryDir)
  .filter(f => imageExts.some(ext => f.toLowerCase().endsWith(ext)))
  .map(f => ({
    src: `${base}/gallery/${f}`,
    alt: f.replace(/\.[^.]+$/, '').replace(/[-_]/g, ' '),
  }));
---

<Layout title="Home">
  <div class="hero">
    <div class="gallery-col">
      <img id="gallery-img" src={photos[0].src} alt={photos[0].alt} class="profile-img" />
      <div class="gallery-controls">
        {photos.length > 1 && <button onclick="movePhoto(-1)" aria-label="Previous">‹</button>}
        {photos.length > 1 && <span id="gallery-counter">1 / {photos.length}</span>}
        {photos.length > 1 && <button onclick="movePhoto(1)" aria-label="Next">›</button>}
        <a id="gallery-open" href={photos[0].src} target="_blank" rel="noopener" aria-label="Open full size" title="Open full size">⤢</a>
      </div>
    </div>

    <div class="bio">
      <h1>🌴 L.A. based comedy writer and actor. 🌴</h1>

      <p>
        Hi! My name is Tao (pronounced tay-oh
        <audio id="player"><source src={`${base}/audio/tao.mp3`} type="audio/mpeg" /></audio>
        <button class="play-btn" onclick="document.getElementById('player').play()" aria-label="Play pronunciation">🔊 play</button>).
      </p>

      <div class="bio-content" set:html={bioHtml} />
    </div>
  </div>
</Layout>

<script define:vars={{ photos }}>
  let current = 0;

  window.movePhoto = function(dir) {
    current = (current + dir + photos.length) % photos.length;
    document.getElementById('gallery-img').src = photos[current].src;
    document.getElementById('gallery-img').alt = photos[current].alt;
    const counter = document.getElementById('gallery-counter');
    if (counter) counter.textContent = `${current + 1} / ${photos.length}`;
    document.getElementById('gallery-open').href = photos[current].src;
  };

  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') movePhoto(-1);
    if (e.key === 'ArrowRight') movePhoto(1);
  });
</script>

<style>
  .hero {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
  }

  .gallery-col {
    flex-shrink: 0;
    width: 500px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .profile-img {
    width: 100%;
    border-radius: 8px;
    display: block;
  }

  .gallery-controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
    font-size: 0.9rem;
    color: #888;
  }

  .gallery-controls button {
    background: none;
    border: none;
    font-size: 1.3rem;
    cursor: pointer;
    color: #555;
    padding: 0 0.1rem;
    line-height: 1;
  }

  .gallery-controls button:hover {
    color: #000;
  }

  .gallery-controls a {
    color: #555;
    font-size: 1.1rem;
    text-decoration: none;
    line-height: 1;
    margin-left: 0.3rem;
  }

  .gallery-controls a:hover {
    color: #000;
  }

  .play-btn {
    display: inline;
    background: none;
    border: 1px solid #aaa;
    border-radius: 4px;
    padding: 0.1rem 0.4rem;
    font-size: 0.85rem;
    cursor: pointer;
    color: #1a0dab;
    vertical-align: middle;
  }

  .play-btn:hover {
    background: #f0f0f0;
    border-color: #666;
  }

  .bio h1 {
    font-size: 1.4rem;
    margin-bottom: 1rem;
  }

  .bio p, .bio-content p {
    margin-bottom: 1rem;
  }

  @media (max-width: 600px) {
    .hero {
      flex-direction: column;
    }

    .gallery-col {
      width: 100%;
    }
  }
</style>
