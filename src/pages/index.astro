---
import Layout from '../layouts/Layout.astro';
import { readdirSync, readFileSync } from 'fs';
import { join } from 'path';
import { marked } from 'marked';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const bioRaw = readFileSync(join(process.cwd(), 'src/content/bio.md'), 'utf-8');
const bioHtml = marked(bioRaw);

const imageExts = ['.jpg', '.jpeg', '.png', '.gif', '.webp', '.avif'];
const galleryDir = join(process.cwd(), 'public/gallery');
const photos = readdirSync(galleryDir)
  .filter(f => imageExts.some(ext => f.toLowerCase().endsWith(ext)))
  .map(f => ({
    src: `${base}/gallery/${f}`,
    alt: f.replace(/\.[^.]+$/, '').replace(/[-_]/g, ' '),
  }));
---

<Layout title="Home">
  <div class="hero">
    <div class="gallery-col">
      <img id="gallery-img" src={photos[0].src} alt={photos[0].alt} class="profile-img" />
      <div class="gallery-controls">
        {photos.length > 1 && <button onclick="movePhoto(-1)" aria-label="Previous">‹</button>}
        {photos.length > 1 && <span id="gallery-counter">1 / {photos.length}</span>}
        {photos.length > 1 && <button onclick="movePhoto(1)" aria-label="Next">›</button>}
        <a id="gallery-open" href={photos[0].src} target="_blank" rel="noopener" title="Open full size">⤢</a>
      </div>
    </div>

    <div class="bio">
      <p class="eyebrow">Comedy writer & actor · Los Angeles</p>
      <h1>Tao Yang</h1>
      <div class="divider"></div>
      <p class="pronounce">
        Hi! My name is Tao (pronounced tay-oh
        <audio id="player"><source src={`${base}/audio/tao.mp3`} type="audio/mpeg" /></audio>
        <button class="play-btn" onclick="document.getElementById('player').play()" aria-label="Play">🔊</button>).
      </p>
      <div class="bio-content" set:html={bioHtml} />
    </div>
  </div>
</Layout>

<script define:vars={{ photos }}>
  let current = 0;

  window.movePhoto = function(dir) {
    const img = document.getElementById('gallery-img');
    current = (current + dir + photos.length) % photos.length;

    img.style.transition = 'none';
    img.style.transform = `translateX(${dir > 0 ? '60px' : '-60px'})`;
    img.style.opacity = '0';

    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        img.src = photos[current].src;
        img.alt = photos[current].alt;
        img.style.transition = 'transform 0.3s ease, opacity 0.3s ease';
        img.style.transform = 'translateX(0)';
        img.style.opacity = '1';
      });
    });

    const counter = document.getElementById('gallery-counter');
    if (counter) counter.textContent = `${current + 1} / ${photos.length}`;
    document.getElementById('gallery-open').href = photos[current].src;
  };

  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') movePhoto(-1);
    if (e.key === 'ArrowRight') movePhoto(1);
  });
</script>

<style>
  .hero {
    display: flex;
    gap: 4rem;
    align-items: flex-start;
  }

  .gallery-col {
    flex-shrink: 0;
    width: 500px;
    overflow: hidden;
  }

  .profile-img {
    width: 100%;
    border-radius: 4px;
    display: block;
  }

  .gallery-controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.6rem;
    color: #aaa;
    font-size: 0.82rem;
  }

  .gallery-controls button {
    background: none;
    border: none;
    font-size: 1.3rem;
    cursor: pointer;
    color: #aaa;
    padding: 0;
    line-height: 1;
    transition: color 0.2s;
  }

  .gallery-controls button:hover { color: #1a1a1a; }

  .gallery-controls a {
    color: #aaa;
    font-size: 1.1rem;
    text-decoration: none;
    margin-left: 0.25rem;
    transition: color 0.2s;
  }

  .gallery-controls a:hover { color: #1a1a1a; }

  .eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #aaa;
    margin-bottom: 0.6rem;
    font-family: 'Lora', serif;
  }

  .bio h1 {
    font-size: 3.5rem;
    line-height: 1;
    margin-bottom: 0;
    color: #1a1a1a;
  }

  .divider {
    width: 40px;
    height: 2px;
    background: #c4b49a;
    margin: 1.5rem 0;
  }

  .pronounce {
    font-size: 0.95rem;
    color: #777;
    margin-bottom: 1.25rem;
  }

  .play-btn {
    background: none;
    border: 1px solid #d9d0c0;
    border-radius: 3px;
    padding: 0.05rem 0.35rem;
    font-size: 0.8rem;
    cursor: pointer;
    color: #777;
    vertical-align: middle;
    transition: border-color 0.2s;
  }

  .play-btn:hover { border-color: #aaa; }

  .bio-content p {
    margin-bottom: 1rem;
    color: #333;
  }

  @media (max-width: 860px) {
    .hero { flex-direction: column; gap: 2rem; }
    .gallery-col { width: 100%; }
    .bio h1 { font-size: 2.5rem; }
  }
</style>
