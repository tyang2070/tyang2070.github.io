---
import Layout from '../layouts/Layout.astro';
import { readdirSync } from 'fs';
import { join } from 'path';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const imageExts = ['.jpg', '.jpeg', '.png', '.gif', '.webp', '.avif'];
const galleryDir = join(process.cwd(), 'public/gallery');
const photos = readdirSync(galleryDir)
  .filter(f => imageExts.some(ext => f.toLowerCase().endsWith(ext)))
  .map(f => ({
    src: `${base}/gallery/${f}`,
    alt: f.replace(/\.[^.]+$/, '').replace(/[-_]/g, ' '),
  }));
---

<Layout title="Home">
  <div class="hero">
    <div class="gallery-col">
      <img id="gallery-img" src={photos[0].src} alt={photos[0].alt} class="profile-img" />
      {photos.length > 1 && (
        <div class="gallery-controls">
          <button onclick="movePhoto(-1)" aria-label="Previous">‹</button>
          <span id="gallery-counter">1 / {photos.length}</span>
          <button onclick="movePhoto(1)" aria-label="Next">›</button>
        </div>
      )}
    </div>

    <div class="bio">
      <h1>🌴 L.A. based comedy writer and actor. 🌴</h1>

      <p>
        Hi! My name is Tao (pronounced tay-oh
        <audio id="player"><source src={`${base}/audio/tao.mp3`} type="audio/mpeg" /></audio>
        <button class="play-btn" onclick="document.getElementById('player').play()" aria-label="Play pronunciation">🔊 play</button>).
        I am a Chinese-American immigrant and became a citizen the day after President Obama got elected.
        I was a CollegeHumor cast member and wrote and starred in dozens of videos which you can see <a href={`${base}/videos`}>here</a>.!
      </p>

      <p>
        I have years of sketch writing experience both online and on stage. I write comedy that is both
        incredibly stupid with strong points of view like this video about how{' '}
        <a href="https://youtu.be/5T35KaUxiSU" target="_blank" rel="noopener">corporate ice-breakers are stupid</a>.
      </p>

      <p>
        I'm also on the Upright Citizen's Brigade house improv team,{' '}
        <em><a href="https://ucbcomedy.com/user/42774" target="_blank" rel="noopener">Jetset</a></em>,
        which you can see either Monday, Thursday, or Friday nights at UCB in LA.
      </p>

      <p>
        Prior to L.A., I was a writer on a house sketch team (aka Maude Night) at the Upright Citizen's Brigade in NYC.
      </p>

      <p>
        I also have life experience outside of comedy! I've had a whole other career as a Data Scientist
        (translation: programmer + stats) and have worked at data-driven organizations like Backstage,
        Grubhub/Seamless, and tumblr. I even coded the pixels that you're looking at right now with
        just my bare hands and a hammer.
      </p>
    </div>
  </div>
</Layout>

<script define:vars={{ photos }}>
  let current = 0;

  window.movePhoto = function(dir) {
    current = (current + dir + photos.length) % photos.length;
    document.getElementById('gallery-img').src = photos[current].src;
    document.getElementById('gallery-img').alt = photos[current].alt;
    const counter = document.getElementById('gallery-counter');
    if (counter) counter.textContent = `${current + 1} / ${photos.length}`;
  };

  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') movePhoto(-1);
    if (e.key === 'ArrowRight') movePhoto(1);
  });
</script>

<style>
  .hero {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
  }

  .gallery-col {
    flex-shrink: 0;
    width: 320px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .profile-img {
    width: 100%;
    border-radius: 8px;
    display: block;
  }

  .gallery-controls {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.4rem;
    font-size: 0.75rem;
    color: #888;
  }

  .gallery-controls button {
    background: none;
    border: none;
    font-size: 1rem;
    cursor: pointer;
    color: #555;
    padding: 0 0.1rem;
    line-height: 1;
  }

  .gallery-controls button:hover {
    color: #000;
  }

  .play-btn {
    display: inline;
    background: none;
    border: 1px solid #aaa;
    border-radius: 4px;
    padding: 0.1rem 0.4rem;
    font-size: 0.85rem;
    cursor: pointer;
    color: #1a0dab;
    vertical-align: middle;
  }

  .play-btn:hover {
    background: #f0f0f0;
    border-color: #666;
  }

  .bio h1 {
    font-size: 1.4rem;
    margin-bottom: 1rem;
  }

  .bio p {
    margin-bottom: 1rem;
  }

  @media (max-width: 600px) {
    .hero {
      flex-direction: column;
    }

    .gallery-col {
      width: 100%;
    }
  }
</style>
