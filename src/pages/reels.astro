---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Reels">
  <h1>Tao Yang's Reels</h1>

  <div class="reel-section">
    <h2>✏️ Writing Reel</h2>
    <div class="video-wrap">
      <iframe
        src="https://www.youtube.com/embed/WND_Ng9Kevo"
        title="Writing Reel"
        allowfullscreen
        loading="lazy"
      ></iframe>
    </div>
  </div>

  <div class="reel-section">
    <h2>🎭 Acting Reel</h2>
    <div class="video-wrap">
      <iframe
        src="https://www.youtube.com/embed/Og2Q6K7LiKM"
        title="Acting Reel"
        allowfullscreen
        loading="lazy"
      ></iframe>
    </div>
  </div>
</Layout>

<style>
  .reel-section {
    margin-bottom: 3rem;
  }

  .video-wrap {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 */
    margin-top: 0.75rem;
  }

  .video-wrap iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
    border-radius: 6px;
  }
</style>
