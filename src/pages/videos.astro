---
import Layout from '../layouts/Layout.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

type Video = {
  title: string;
  caption?: string;
  // YouTube
  id?: string;
  // Local
  src?: string;
  thumbnail?: string;
};

const raw = readFileSync(join(process.cwd(), 'src/content/videos.yaml'), 'utf-8');
const sections = yaml.load(raw) as { section: string; videos: Video[] }[];

function thumbUrl(v: Video) {
  if (v.id) return `https://img.youtube.com/vi/${v.id}/hqdefault.jpg`;
  if (v.thumbnail) return `${base}${v.thumbnail}`;
  return null;
}

function videoData(v: Video) {
  return JSON.stringify({
    type: v.id ? 'youtube' : 'local',
    id: v.id ?? null,
    src: v.src ? `${base}${v.src}` : null,
    title: v.title,
    caption: v.caption ?? null,
  });
}
---

<Layout title="Videos">
  <h1>Videos</h1>

  {sections.map(section => (
    <section class="video-section">
      <h2>{section.section}</h2>
      <div class="grid">
        {section.videos.map(v => {
          const thumb = thumbUrl(v);
          return (
            <button class="card" data-video={videoData(v)}>
              <div class="thumb-wrap">
                {thumb
                  ? <img src={thumb} alt={v.title} loading="lazy" />
                  : <div class="thumb-placeholder">▶</div>
                }
                <div class="play-icon">▶</div>
              </div>
              <p class="card-title">{v.title}</p>
              {v.caption && <p class="card-caption">{v.caption}</p>}
            </button>
          );
        })}
      </div>
    </section>
  ))}

  <!-- Modal -->
  <dialog id="video-modal">
    <div class="modal-inner">
      <div class="modal-header">
        <span id="modal-title"></span>
        <button class="modal-close" aria-label="Close">✕</button>
      </div>
      <div class="video-wrap" id="video-wrap"></div>
      <p class="modal-caption" id="modal-caption"></p>
    </div>
  </dialog>
</Layout>

<script>
  const modal = document.getElementById('video-modal') as HTMLDialogElement;
  const wrap = document.getElementById('video-wrap')!;
  const titleEl = document.getElementById('modal-title')!;
  const captionEl = document.getElementById('modal-caption')!;

  function openVideo(dataStr: string) {
    const data = JSON.parse(dataStr);

    titleEl.textContent = data.title;
    captionEl.textContent = data.caption ?? '';
    captionEl.style.display = data.caption ? 'block' : 'none';
    wrap.innerHTML = '';

    if (data.type === 'youtube' && data.id) {
      wrap.style.paddingBottom = '56.25%';
      wrap.style.position = 'relative';
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube.com/embed/${data.id}?autoplay=1`;
      iframe.title = data.title;
      iframe.allowFullscreen = true;
      iframe.allow = 'autoplay';
      wrap.appendChild(iframe);
    } else if (data.type === 'local' && data.src) {
      wrap.style.paddingBottom = '0';
      wrap.style.position = 'static';
      const video = document.createElement('video');
      video.src = data.src;
      video.controls = true;
      video.autoplay = true;
      video.style.cssText = 'width:100%;max-height:80vh;display:block;background:#000;';
      wrap.appendChild(video);
    }

    modal.showModal();
  }

  function closeVideo() {
    wrap.innerHTML = '';
    modal.close();
  }

  // Delegate clicks on all cards
  document.addEventListener('click', (e) => {
    const card = (e.target as Element).closest('.card') as HTMLElement | null;
    if (card?.dataset.video) openVideo(card.dataset.video);
  });

  // Close on backdrop click
  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeVideo();
  });

  document.querySelector('.modal-close')?.addEventListener('click', closeVideo);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal.open) closeVideo();
  });
</script>

<style>
  h1 { margin-bottom: 2rem; }

  .video-section { margin-bottom: 3rem; }

  .video-section h2 {
    margin-bottom: 1.25rem;
    margin-top: 0;
    font-size: 1.1rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #aaa;
    font-family: 'Lora', serif;
    font-weight: 400;
    border-bottom: 1px solid #d9d0c0;
    padding-bottom: 0.5rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.25rem;
    align-items: start;
  }

  .card {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    text-align: left;
  }

  .thumb-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 4px;
    background: #e8e0d4;
  }

  .thumb-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.25s ease;
  }

  .thumb-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    color: #c4b49a;
  }

  .play-icon {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.75rem;
    color: #fff;
    opacity: 0;
    background: rgba(0,0,0,0.3);
    transition: opacity 0.2s ease;
  }

  .card:hover .thumb-wrap img { transform: scale(1.04); }
  .card:hover .play-icon { opacity: 1; }

  .card-title {
    margin: 0.5rem 0 0;
    font-size: 0.88rem;
    line-height: 1.4;
    color: #333;
  }

  .card-caption {
    margin: 0.25rem 0 0;
    font-size: 0.78rem;
    color: #999;
    line-height: 1.3;
  }

  /* Modal */
  dialog {
    padding: 0;
    border: none;
    background: transparent;
    max-width: 100vw;
    max-height: 100vh;
    width: 100vw;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  dialog::backdrop {
    background: rgba(20, 15, 10, 0.85);
    backdrop-filter: blur(4px);
  }

  dialog:not([open]) { display: none; }

  .modal-inner {
    width: min(860px, 92vw);
    background: #1a1510;
    border-radius: 6px;
    overflow: hidden;
  }

  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    color: #ccc;
    font-size: 0.88rem;
    font-family: 'Lora', serif;
  }

  .modal-close {
    background: none;
    border: none;
    color: #aaa;
    font-size: 1.1rem;
    cursor: pointer;
    line-height: 1;
    padding: 0.2rem;
    transition: color 0.2s;
  }

  .modal-close:hover { color: #fff; }

  .modal-caption {
    padding: 0.6rem 1rem 0.75rem;
    color: #888;
    font-size: 0.82rem;
    font-family: 'Lora', serif;
    font-style: italic;
    margin: 0;
  }

  #video-wrap {
    width: 100%;
  }

  #video-wrap iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  @media (max-width: 500px) {
    .grid { grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); }
  }
</style>
